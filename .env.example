# Banco de dados (Supabase — usar Session Pooler porta 5432, IPv4)
DATABASE_URL=postgresql+asyncpg://postgres.PROJETO:SENHA@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# WhatsApp (WAHA self-hosted)
WAHA_BASE_URL=https://SEU-WAHA-URL
WAHA_API_KEY=SUA-WAHA-API-KEY
WAHA_SESSION=clinica-simioni

# Redis
REDIS_URL=redis://default:SENHA@HOST:6379

# JWT (gere uma string aleatória longa)
JWT_SECRET=GERE-UMA-STRING-ALEATORIA-LONGA-AQUI

# App
APP_ENV=production
APP_PORT=8080
CORS_ORIGINS=https://SEU-DOMINIO-FRONTEND

# IA (opcional — para o assistente Claude)
ANTHROPIC_API_KEY=

# Frontend
VITE_API_URL=https://SEU-DOMINIO-BACKEND
